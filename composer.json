{
  "name": "relodev/laravel-translatable",
  "description": "Lightweight bilingual (FR/EN) translation for Laravel models and views",
  "keywords": ["laravel", "translation", "multilingual", "eloquent"],
  "type": "library",
  "license": "MIT",
  "authors": [{
    "name": "Aurel Ayena",
    "email": "ayenaaurel15@gmail.com"
  }],
  "require": {
    "php": "^8.1",
    "illuminate/support": "^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0|^9.0",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Relodev\\Translatable\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Relodev\\Translatable\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Relodev\\Translatable\\TranslatableServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}

